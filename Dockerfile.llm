# LLM Server — Qwen 2.5 7B Q4_K_M через llama.cpp
# Отдельный контейнер, чтобы загрузка модели (4.5 ГБ) не мешала бэкенду

FROM alpine:3.19 AS builder

RUN apk add --no-cache build-base cmake git curl

WORKDIR /build
RUN git clone --depth 1 --branch b4624 https://github.com/ggerganov/llama.cpp . \
    && cmake -B build \
    && cmake --build build --config Release -j$(nproc) --target llama-server

FROM alpine:3.19

RUN apk add --no-cache libstdc++ curl

COPY --from=builder /build/build/bin/llama-server /usr/local/bin/llama-server

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

ENTRYPOINT ["llama-server", \
    "--model", "/models/qwen2.5-7b-q4_k_m.gguf", \
    "--host", "0.0.0.0", \
    "--port", "8080", \
    "--ctx-size", "2048", \
    "--threads", "4"]
